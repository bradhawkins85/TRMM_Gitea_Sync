# Copy this file to .env and fill in your values.
# The .env file is listed in .gitignore and will not be committed.

# ── Tactical RMM ────────────────────────────────────────────────────────────
TRMM_API_URL=https://rmm.example.com
TRMM_API_KEY=your-trmm-api-key

# ── Gitea (sync.py) ─────────────────────────────────────────────────────────
GITEA_URL=https://gitea.example.com
GITEA_TOKEN=your-gitea-access-token
GITEA_OWNER=your-gitea-user-or-org
GITEA_REPO=your-gitea-repo-name
GITEA_BRANCH=main

# ── GitHub (sync_github.py) ─────────────────────────────────────────────────
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_OWNER=your-github-user-or-org
GITHUB_REPO=your-github-repo-name
GITHUB_BRANCH=main
# Leave blank to use the default public GitHub API; set for GitHub Enterprise:
# GITHUB_API_URL=https://github.example.com/api/v3

# ── SSL ─────────────────────────────────────────────────────────────────────
# Set to true to disable SSL certificate verification (not recommended for production)
IGNORE_SSL=false
